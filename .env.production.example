# Copy this file to .env.production and replace placeholder values before deployment.
NODE_ENV=production
PORT=3000
BASE_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

MONGO_DB_URI=mongodb+srv://user:password@host/db

JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASS=change_me
MAIL_FROM="UTE Doctor <no-reply@example.com>"
OTP_EXPIRES=5m

CLOUDINARY_CLOUD_NAME=change_me
CLOUDINARY_API_KEY=change_me
CLOUDINARY_API_SECRET=change_me

VN_PAY_TMNCODE=change_me
VN_PAY_HASHSECRET=change_me
VN_PAY_RETURNURL=https://api.example.com/api/payment/vnpay/return
VN_PAY_EXPIRE_MINUTES=15

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
SOCKET_PRESENCE_TTL_SECONDS=60

RABBITMQ_ENABLED=true
RABBITMQ_URL=amqp://user:password@rabbitmq:5672

CHAT_WRITE_MODE=dual
CHAT_REALTIME_MODE=direct
CHAT_QUEUE_MAX_RETRY=3

NOTIFICATION_JOBS_QUEUE=notification.jobs
NOTIFICATION_JOBS_EXCHANGE=notification.jobs
NOTIFICATION_REDIS_CHANNEL=notification
NOTIFICATION_MAX_RETRY=3

COIN_REWARD_RATE=0.1
COIN_EXPIRY_DAYS=3
COIN_DEFAULT_EXPIRE_DAYS=180
COIN_EXPIRY_REMINDER_DAYS=3
COIN_EXPIRY_REMINDER_QUEUE=coin.expiry.reminder
COIN_EXPIRY_REMINDER_EXCHANGE=coin.expiry.reminder
COIN_EXPIRY_REMINDER_REDIS_CHANNEL=coin.expiry.reminder
COIN_EXPIRY_REMINDER_SCHEDULER_INTERVAL_MS=10000
COIN_EXPIRY_REMINDER_MAX_RETRY=3
COIN_EXPIRY_REMINDER_DISPATCH_BUFFER_MS=60000
COIN_EXPIRY_REMINDER_DISPATCH_LOCK_TTL_SECONDS=90
COIN_EXPIRY_REMINDER_PROCESS_LOCK_TTL_SECONDS=300

CONSULTATION_FEE=150000
INSURANCE_COVERAGE_RATE=0
APPOINTMENT_CANCEL_REFUND_RATE=1
